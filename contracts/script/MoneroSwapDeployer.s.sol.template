//
// Run with
// forge script --via-ir --optimize true --optimizer-runs $(optimizer-runs) --rpc-url https://rpc.gnosischain.com/ --trezor --verify --value 0.1ether --broadcast script/MoneroSwapDeployer.s.sol
// Replace --trezor by either --ledger or --mnemonic
//

contract MoneroSwapDeployer is Script {

    address OWNER = address(MONEROSWAP_OWNER);
    bytes32 constant SALT = DEPLOYMENT_SALT;
    uint256 constant VALUE = 0;

    function run() public {
        vm.startBroadcast();

        MoneroSwap moneroswap = new MoneroSwap{salt: SALT, value: VALUE}(OWNER);
        console.log('Contract addresss: ',address(moneroswap));

        vm.stopBroadcast();
    }
}
